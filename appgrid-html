<style>
    . appgrid-html {
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* 3 columns for a busy, full look */
        gap: 20px;
        padding: 20px;
        max-width: 500px;
        margin: 0 auto;
    }

    .app-icon {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #111; /* Dark background */
        border: 1px solid #333;
        border-radius: 15px;
        padding: 15px 10px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .app-icon:hover {
        border-color: #ffd700; /* Gold glow on hover */
        transform: translateY(-5px);
        background: #1a1a1a;
    }

    .app-icon i {
        font-style: normal;
        font-size: 30px; /* Big, clear icons */
        margin-bottom: 8px;
    }

    .app-icon span {
        color: #fff;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Special style for the Ads Tool to make it stand out */
    .app-icon.promo {
        border-color: #ffd700;
        background: rgba(255, 215, 0, 0.05);
    }
</style>

<div class="app-grid">
    <div class="app-icon" onclick="window.location.href='live.html'">
        <i>🎥</i><span>Live</span>
    </div>
    
    <div class="app-icon" onclick="window.location.href='market.html'">
        <i>🛒</i><span>Market</span>
    </div>

    <div class="app-icon promo" onclick="window.location.href='ads.html'">
        <i>📈</i><span>Ads Tool</span>
    </div>

    <div class="app-icon" onclick="window.location.href='games.html'">
        <i>🎮</i><span>Games</span>
    </div>

    <div class="app-icon" onclick="window.location.href='kitchen.html'">
        <i>🍽️</i><span>Kitchen</span>
    </div>

    <div class="app-icon" onclick="window.location.href='design.html'">
        <i>🎨</i><span>Studio</span>
    </div>

    <div class="app-icon" onclick="window.location.href='music.html'">
        <i>🎵</i><span>Music</span>
    </div>

    <div class="app-icon" onclick="window.location.href='content.html'">
        <i>✍️</i><span>Stories</span>
    </div>
</div>
