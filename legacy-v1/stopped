<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NAWI | Stories</title>
    <style>
        body { background: #000; color: #fff; margin: 0; font-family: sans-serif; height: 100vh; display: flex; flex-direction: column; }
        .story-header { padding: 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #222; }
        .story-timer { height: 3px; background: #333; width: 100%; position: relative; }
        .timer-progress { height: 100%; background: #D4AF37; width: 40%; } /* Shows viewing time */
        
        .story-display { flex: 1; display: flex; align-items: center; justify-content: center; padding: 20px; text-align: center; font-size: 24px; font-weight: bold; }
        
        .earning-notif { background: #D4AF37; color: #000; padding: 15px; text-align: center; font-weight: bold; border-radius: 20px 20px 0 0; }
        .nav-footer { padding: 20px; background: #111; display: flex; justify-content: space-around; }
        .nav-btn { color: #888; text-decoration: none; font-size: 14px; }
    </style>
</head>
<body>

    <div class="story-timer"><div class="timer-progress"></div></div>

    <div class="story-header">
        <span style="font-weight: bold;">User_102 Story</span>
        <span style="color: #D4AF37;">5s left</span>
    </div>

    <div class="story-display">
        "Just earned 50 Coins 🪙 in the Games Studio! The Empire is real! 🔥"
    </div>

    <div class="earning-notif">
        Keep watching to earn +0.5 Coins 🪙
    </div>

    <div class="nav-footer">
        <a href="app-grid.html" class="nav-btn">Exit</a>
        <a href="#" class="nav-btn" style="color:#D4AF37">Next Story →</a>
    </div>

</body>
</html>
