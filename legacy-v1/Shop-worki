<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NAWI EMPIRE | DISCOVER</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --gold: #D4AF37; --dark: #000; --search-bg: #111; }
        body { background: var(--dark); color: white; font-family: 'Inter', sans-serif; margin: 0; padding-bottom: 100px; overflow-x: hidden; }
        
        /* SEARCH HEADER */
        .search-header { padding: 30px 20px 15px; background: #000; position: sticky; top: 0; z-index: 100; border-bottom: 1px solid #1a1a1a; }
        .search-input-wrapper { display: flex; align-items: center; background: var(--search-bg); border: 1px solid #222; border-radius: 12px; padding: 12px 15px; }
        .search-input-wrapper input { background: transparent; border: none; color: white; width: 100%; margin-left: 10px; outline: none; font-size: 14px; }

        /* SECTION TITLES */
        .section-title { padding: 25px 20px 10px; font-size: 12px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; font-weight: 900; }

        /* TRENDING LIST */
        .trend-item { display: flex; align-items: center; justify-content: space-between; padding: 15px 20px; border-bottom: 1px solid #111; transition: 0.3s; }
        .profile-info { display: flex; align-items: center; gap: 15px; }
        .trend-avatar { width: 45px; height: 45px; background: #111; border-radius: 50%; border: 1px solid var(--gold); display: flex; align-items: center; justify-content: center; font-weight: bold; color: var(--gold); }
        .name-stack { display: flex; flex-direction: column; }
        .username { font-weight: bold; font-size: 15px; letter-spacing: 0.5px; }
        .subtitle { font-size: 11px; color: #666; margin-top: 2px; }

        /* ACTION BUTTON */
        .view-btn { background: none; border: 1px solid var(--gold); color: var(--gold); padding: 6px 16px; border-radius: 20px; font-size: 11px; font-weight: bold; cursor: pointer; text-transform: uppercase; }
        .view-btn:hover { background: var(--gold); color: black; }

        /* BOTTOM NAVIGATION (MASTER NAV) */
        .master-nav { position: fixed; bottom: 0; width: 100%; background: #080808; border-top: 1px solid #111; display: flex; justify-content: space-around; padding: 15px 0; z-index: 1000; }
        .nav-box { text-align: center; cursor: pointer; color: #555; text-decoration: none; transition: 0.3s; }
        .nav-box p { font-size: 10px; margin: 5px 0 0; font-weight: bold; }
        .active-tab { color: var(--gold) !important; }
        .plus-btn { background: var(--gold); width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: -10px; box-shadow: 0 4px 10px rgba(212, 175, 55, 0.3); }
    </style>
</head>
<body>

    <div class="search-header">
        <div class="search-input-wrapper">
            <i class="fa-solid fa-magnifying-glass" style="color: var(--gold);"></i>
            <input type="text" placeholder="Explore the Empire..." id="searchInput">
        </div>
    </div>

    <div class="section-title">Trending Brands & Studios</div>

    <div class="trend-item">
        <div class="profile-info">
            <div class="trend-avatar" style="background: var(--gold); color: black;">NS</div>
            <div class="name-stack">
                <span class="username">NAWI-EMPIRE design studio</span>
                <span class="subtitle">Luxury Branding Lead</span>
            </div>
        </div>
        <button class="view-btn" onclick="window.location.href='design.html'">HIRE</button>
    </div>

    <div class="trend-item">
        <div class="profile-info">
            <div class="trend-avatar">🛒</div>
            <div class="name-stack">
                <span class="username">Empire Marketplace</span>
                <span class="subtitle">Top Verified Ads</span>
            </div>
        </div>
        <button class="view-btn" onclick="window.location.href='market.html'">SHOP</button>
    </div>

    <nav class="master-nav">
        <a href="index.html" class="nav-box">
            <i class="fa-solid fa-house" style="font-size: 20px;"></i>
            <p>Home</p>
        </a>
        <a href="discover.html" class="nav-box active-tab">
            <i class="fa-solid fa-compass" style="font-size: 20px;"></i>
            <p>Discover</p>
        </a>
        <div onclick="window.location.href='app-grid.html'" class="nav-box">
            <div class="plus-btn"><i class="fa-solid fa-plus" style="font-size: 20px; color: black;"></i></div>
        </div>
        <a href="inbox.html" class="nav-box">
            <i class="fa-solid fa-message" style="font-size: 20px;"></i>
            <p>Inbox</p>
        </a>
        <a href="profile.html" class="nav-box">
            <i class="fa-solid fa-user" style="font-size: 20px;"></i>
            <p>Profile</p>
        </a>
    </nav>

    <script>
        // Simple search feedback for your users
        document.getElementById('searchInput').addEventListener('keyup', function(e) {
            console.log("Searching Empire for: " + this.value);
        });
    </script>

</body>
</html>
